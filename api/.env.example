# API Environment Configuration
# This file serves as a template for all environment variables used in the application
# Copy this file to .env and fill in your values
# ----------------------------------------------------------------------------

# =============================================================================
# Environment and Debug Settings
# =============================================================================
# Environment setting - development for local development, production for production
ENVIRONMENT=development
# Debug mode - enabled for development
DEBUG=true

# =============================================================================
# OpenAI API Configuration
# =============================================================================
# OpenAI API key (required for LLM and embeddings via AISuite)
OPENAI_API_KEY=
# Model ID with provider prefix for AISuite (format: "provider:model")
# Examples: openai:gpt-4o-mini, openai:gpt-4o, anthropic:claude-3-5-sonnet
OPENAI_MODEL=openai:gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
MAX_TOKENS=4096
# Temperature for LLM responses (0.0-2.0, default: 0.7)
LLM_TEMPERATURE=0.7

# =============================================================================
# API Configuration
# =============================================================================
# Admin API key for protected endpoints
ADMIN_API_KEY=dev_admin_key

# =============================================================================
# External API Configuration
# =============================================================================
# Bisq API URL - local development URL (Docker uses a different network address)
BISQ_API_URL=http://localhost:8090
# Safety guard: when true, BISQ_API_URL must target localhost/127.0.0.1/host.docker.internal
BISQ_API_LOCAL_ONLY=true

# Support agent nicknames (comma-separated list of official support staff)
# Required for FAQ extraction from support chats
# Example: SUPPORT_AGENT_NICKNAMES=suddenwhipvapor,strayorigin,toruk-makto
# If not configured, no messages will be marked as support messages
SUPPORT_AGENT_NICKNAMES=

# =============================================================================
# CORS Configuration
# =============================================================================
# CORS_ORIGINS for local direct development - comma-separated values
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Data Directory Configuration
# =============================================================================
# Base directory for all data files
DATA_DIR=api/data

# =============================================================================
# RAG Service Configuration
# =============================================================================
# Maximum number of chat history entries to include
MAX_CHAT_HISTORY_LENGTH=10
# Maximum length of context to include in prompt
MAX_CONTEXT_LENGTH=15000
# Maximum length to log in samples
MAX_SAMPLE_LOG_LENGTH=200

# =============================================================================
# Admin Settings
# =============================================================================
# Maximum number of unique issues to track in analytics
MAX_UNIQUE_ISSUES=15

# =============================================================================
# Matrix Integration Configuration
# =============================================================================
# Matrix homeserver
MATRIX_HOMESERVER_URL=https://matrix.org

# Optional Bisq2 channel ID used when Internal Notice Target is set to Staff Room
# for the Bisq2 channel.
BISQ2_STAFF_NOTIFICATION_TARGET=
BISQ2_CHATOPS_ENABLED=false
BISQ2_CHATOPS_CHANNEL_IDS=

# Matrix sync lane (staff channel ingestion for FAQ extraction)
MATRIX_SYNC_ENABLED=false
# When true, sends encrypted replies even if room devices are unverified
# Keep false by default; enable only when explicitly needed.
MATRIX_SYNC_IGNORE_UNVERIFIED_DEVICES=false
MATRIX_SYNC_USER=
MATRIX_SYNC_PASSWORD=
# Matrix room IDs for sync ingestion (public support room local test default)
MATRIX_SYNC_ROOMS=!ilodKeOTMMMDTlGhkf:matrix.org
# Dedicated staff room for matrix escalation notifications.
# For local testing you can point this to the same room as MATRIX_ALERT_ROOM.
MATRIX_STAFF_ROOM=!KQdmdCuJsNAjLhkIre:matrix.org
MATRIX_CHATOPS_ENABLED=false
MATRIX_CHATOPS_ROOM_IDS=
# Session file for sync lane
MATRIX_SYNC_SESSION_FILE=/data/matrix_session.json

# Matrix alert lane (Prometheus Alertmanager notifications)
MATRIX_ALERT_USER=
MATRIX_ALERT_PASSWORD=
# Staff room for escalations/alerts (local test default)
MATRIX_ALERT_ROOM=!KQdmdCuJsNAjLhkIre:matrix.org
MATRIX_ALERT_SESSION_FILE=/data/matrix_alert_session.json

# Trust monitoring defaults to on in the app config. For production rollout,
# start with TRUST_MONITOR_ENABLED=false and then enable with a real
# TRUST_MONITOR_ACTOR_KEY_SECRET.
TRUST_MONITOR_ENABLED=false
TRUST_MONITOR_NAME_COLLISION_ENABLED=true
TRUST_MONITOR_SILENT_OBSERVER_ENABLED=true
TRUST_MONITOR_ALERT_SURFACE=admin_ui
TRUST_MONITOR_MATRIX_PUBLIC_ROOMS=
TRUST_MONITOR_MATRIX_STAFF_ROOM=
TRUST_MONITOR_SILENT_OBSERVER_WINDOW_DAYS=14
TRUST_MONITOR_EARLY_READ_WINDOW_SECONDS=30
TRUST_MONITOR_MINIMUM_OBSERVATIONS=10
TRUST_MONITOR_MINIMUM_EARLY_READ_HITS=8
TRUST_MONITOR_READ_TO_REPLY_RATIO_THRESHOLD=12.0
TRUST_MONITOR_EVIDENCE_TTL_DAYS=7
TRUST_MONITOR_AGGREGATE_TTL_DAYS=30
TRUST_MONITOR_FINDING_TTL_DAYS=30
TRUST_MONITOR_ACTOR_KEY_SECRET=
